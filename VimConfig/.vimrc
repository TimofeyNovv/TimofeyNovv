" ===========================
" Vim config by TimofeyNovv
" ===========================

set nocompatible
" Отключает режим совместимости со старым vi и включает нормальное поведение Vim.

syntax on
" Включает подсветку синтаксиса.

filetype plugin indent on
" Определяет тип файла, включает плагины для этого типа файла и правила автоотступов.

set termguicolors
" Включает true color (24-битные цвета) в терминале.

set background=dark
" Говорит Vim, что используется тёмная тема оформления.


" ===========================
" Плагины
" ===========================

call plug#begin('~/.vim/plugged')
" Начало списка плагинов vim-plug.
" Все плагины будут ставиться в папку ~/.vim/plugged.

Plug 'neoclide/coc.nvim', {'branch': 'release'}
" Устанавливает coc.nvim — систему автодополнения, диагностики и LSP.
" Используется ветка release, рекомендованная разработчиками.

Plug 'catppuccin/vim', { 'as': 'catppuccin' }
" Устанавливает тему Catppuccin для Vim.
" 'as' задаёт короткое имя, под которым плагин будет зарегистрирован.

call plug#end()
" Завершает список плагинов vim-plug.


" ===========================
" Тема
" ===========================

colorscheme catppuccin_mocha
" Включает цветовую схему Catppuccin Mocha.


" ===========================
" Внешний вид
" ===========================

set number
" Показывает обычные номера строк.

set relativenumber
" Показывает относительные номера строк вокруг текущей строки.
" Удобно для навигации и команд вида 5j, 3k и т.д.

set cursorline
" Подсвечивает строку, на которой стоит курсор.

set signcolumn=yes
" Всегда показывает колонку слева под значки ошибок, предупреждений и git-меток.
" Это предотвращает "дёргание" текста при появлении диагностики.

set scrolloff=6
" Оставляет минимум 6 строк сверху и снизу от курсора при прокрутке.

set nowrap
" Отключает перенос длинных строк на следующую визуальную строку.

set ruler
" Показывает текущую позицию курсора: строку, столбец и другую служебную информацию.

set mouse=a
" Включает поддержку мыши во всех режимах Vim.


" ===========================
" Отступы для C++
" ===========================

set tabstop=4
" Один символ табуляции отображается как 4 пробела.

set shiftwidth=4
" Команды автоотступа используют шаг 4 пробела.

set softtabstop=4
" При нажатии Tab/Backspace в режиме вставки используется шаг 4 пробела.

set expandtab
" Превращает Tab в пробелы вместо настоящего символа табуляции.

set smarttab
" Делает Tab умнее в начале строки, учитывая настройки отступов.

set smartindent
" Включает базовое умное автоформатирование отступов для кода.


" ===========================
" Поиск
" ===========================

set hlsearch
" Подсвечивает все найденные совпадения после поиска.

set incsearch
" Показывает результаты поиска по мере ввода запроса.

set ignorecase
" Игнорирует регистр букв при поиске.

set smartcase
" Если в поисковом запросе есть заглавные буквы,
" поиск становится чувствительным к регистру.


" ===========================
" Completion
" ===========================

set hidden
" Позволяет переключаться между буферами без обязательного сохранения файла.

set updatetime=300
" Уменьшает задержку обновления внутренних событий Vim до 300 мс.
" Это помогает coc.nvim быстрее показывать диагностику и подсказки.

set completeopt=menuone,noinsert,noselect
" Настраивает поведение меню автодополнения:
" menuone   — показывать меню даже при одном варианте,
" noinsert  — не вставлять вариант автоматически,
" noselect  — не выбирать вариант автоматически.

set pumheight=12
" Ограничивает высоту popup-меню автодополнения до 12 строк.


" ===========================
" Русская раскладка для команд
" ===========================

set langmap=ФИСВУАПРШОЛДЬТЩЗЙКЫЕГМЦЧНЯ;ABCDEFGHIJKLMNOPQRSTUVWXYZ,фисвуапршолдьтщзйкыегмцчня;abcdefghijklmnopqrstuvwxyz
" Позволяет вводить команды Vim в русской раскладке,
" сопоставляя русские буквы с английскими.


" ===========================
" Безопасность
" ===========================

set modelines=0
" Отключает modelines внутри файлов.
" Это безопаснее и исключает применение настроек из содержимого файла.


" ===========================
" Подгонка цветов под kitty
" ===========================

highlight Normal       guibg=NONE ctermbg=NONE
" Делает фон основной области Vim прозрачным/неокрашенным,
" чтобы лучше сочетаться с фоном kitty.

highlight SignColumn   guibg=NONE ctermbg=NONE
" Делает фон колонки со значками ошибок и предупреждений прозрачным/неокрашенным.

highlight LineNr       guifg=#6c7086
" Задаёт цвет обычных номеров строк.

highlight CursorLineNr guifg=#f9e2af gui=bold
" Задаёт цвет номера текущей строки и делает его жирным.

highlight Pmenu    guibg=#1e1e2e guifg=#cdd6f4
" Настраивает обычный вид меню автодополнения.

highlight PmenuSel guibg=#313244 guifg=#cdd6f4 gui=bold
" Настраивает вид выбранного элемента в меню автодополнения.

highlight CocErrorSign   guifg=#f38ba8
" Задаёт цвет значка ошибки от coc.nvim.

highlight CocWarningSign guifg=#f9e2af
" Задаёт цвет значка предупреждения от coc.nvim.

highlight CocInfoSign    guifg=#89b4fa
" Задаёт цвет информационного значка от coc.nvim.

highlight CocHintSign    guifg=#94e2d5
" Задаёт цвет значка подсказки от coc.nvim.


" ===========================
" Горячие клавиши Coc
" ===========================

inoremap <silent><expr> <Tab> pumvisible() ? "\<C-n>" : "\<Tab>"
" В режиме вставки:
" если меню автодополнения открыто — Tab переключает на следующий вариант,
" иначе работает как обычный Tab.

inoremap <silent><expr> <S-Tab> pumvisible() ? "\<C-p>" : "\<BS>"
" В режиме вставки:
" если меню автодополнения открыто — Shift+Tab переключает на предыдущий вариант,
" иначе работает как Backspace.

inoremap <silent><expr> <CR> pumvisible() ? coc#pum#confirm() : "\<CR>"
" В режиме вставки:
" если меню автодополнения открыто — Enter подтверждает выбранный вариант,
" иначе вставляет обычный перевод строки.

nmap <silent> gd <Plug>(coc-definition)
" В обычном режиме gd переходит к определению символа под курсором.

nmap <silent> gr <Plug>(coc-references)
" В обычном режиме gr показывает все использования символа.

nmap <silent> K  :call CocActionAsync('doHover')<CR>
" В обычном режиме K показывает hover-подсказку по символу под курсором.

nmap <silent> <leader>rn <Plug>(coc-rename)
" В обычном режиме <leader>rn запускает переименование символа во всех местах.
